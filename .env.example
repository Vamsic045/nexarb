# ══════════════════════════════════════════════════════
# NEXARB — Environment Configuration
# Copy to .env and fill in all values
# ══════════════════════════════════════════════════════

# ── Database ────────────────────────────────────────────
DB_PASSWORD=change_this_to_strong_password_123!

# ── Security Keys ───────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_64_CHAR_HEX
JWT_SECRET=REPLACE_WITH_64_CHAR_HEX

# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=REPLACE_WITH_FERNET_KEY=

# ── Admin Login ─────────────────────────────────────────
ADMIN_USERNAME=admin
# Generate: python -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt()).decode())"
ADMIN_PASSWORD_HASH=$2b$12$REPLACE_WITH_BCRYPT_HASH

# ── CORS Origins ────────────────────────────────────────
ALLOWED_ORIGINS=["https://yourdomain.com"]

# ── Telegram Alerts (optional) ──────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── App Settings ────────────────────────────────────────
DEBUG=false
